generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  COORDENADOR
  ALUNO
  ORIENTADOR
}

enum UserStatus {
  PENDENTE
  ATIVO
  REJEITADO
}

model User {
  id                    String               @id @default(cuid())
  nome_completo         String
  email                 String               @unique
  username              String               @unique
  senha_hash            String
  perfil                Perfil
  matricula             String?
  status                UserStatus           @default(ATIVO)
  failed_login_attempts Int                  @default(0)
  blocked_until         DateTime?
  ativo                 Boolean              @default(true)
  criado_em             DateTime             @default(now())
  password_reset_tokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  token     String   @id
  user_id   String
  expira_em DateTime
  usado     Boolean  @default(false)
  criado_em DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

enum TipoTCC {
  MONOGRAFIA
  ARTIGO
  RELATORIO
}

enum StatusTCC {
  RASCUNHO
  AGUARDANDO_ACEITE
  APROVADO
  REJEITADO
}

model TCC {
  id              String   @id @default(cuid())
  titulo          String
  tipo            TipoTCC
  aluno_id        String
  orientador_id   String
  coorientador_id String?
  periodo         String
  status          StatusTCC @default(AGUARDANDO_ACEITE)
  prazo_excedido  Boolean   @default(false)
  criado_em       DateTime  @default(now())
  atualizado_em   DateTime  @updatedAt

  @@unique([aluno_id, periodo])
  @@map("tccs")
}