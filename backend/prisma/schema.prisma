generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  COORDENADOR
  ALUNO
  ORIENTADOR
}

enum UserStatus {
  PENDENTE
  ATIVO
  REJEITADO
}

enum TipoTCC {
  TODOS               @map("Todos")
  MONOGRAFIA          @map("Monografia")
  ARTIGO              @map("Artigo")
  RELATORIO_ESTAGIO   @map("Relatorio de Estagio")
}

enum StatusTCC {
  AGUARDANDO_ACEITE
  EM_ANDAMENTO
  SEM_ORIENTADOR
  APROVADO
  REJEITADO
}

enum AcaoEdicaoTCC {
  CRIACAO
  EDICAO
  ACEITE_ORIENTACAO
  RECUSA_ORIENTACAO
}

model User {
  id                    String               @id @default(cuid())
  nome_completo         String
  email                 String               @unique
  username              String               @unique
  senha_hash            String
  perfil                Perfil
  matricula             String?
  status                UserStatus           @default(ATIVO)
  failed_login_attempts Int                  @default(0)
  blocked_until         DateTime?
  ativo                 Boolean              @default(true)
  email_prazos_orientandos Boolean           @default(true)
  notificacao_antecedencia_dias Int          @default(3)
  email_notas_parciais Boolean               @default(true)
  email_notas_finais   Boolean               @default(true)
  publicar_tcc_portal_publico Boolean        @default(false)
  compartilhar_dados_terceiros Boolean       @default(false)
  privacidade_atualizado_em DateTime?
  criado_em             DateTime             @default(now())
  password_reset_tokens PasswordResetToken[]
  tccs_como_aluno       TCC[]                @relation("AlunoTCC")
  tccs_como_orientador  TCC[]                @relation("OrientadorTCC")
  tccs_como_coorientador TCC[]               @relation("CoorientadorTCC")
  tcc_edit_logs         TCCEditLog[]         @relation("ActorTCCEdit")
  submissoes_entregaveis SubmissaoEntregavel[]
  orientacao_sessoes_aluno OrientacaoSessao[] @relation("AlunoOrientacaoSessao")
  orientacao_sessoes_orientador OrientacaoSessao[] @relation("OrientadorOrientacaoSessao")
  apresentacoes_artigo ApresentacaoArtigo[] @relation("AlunoApresentacaoArtigo")
  audit_logs            AuditLog[]
  notificacoes_prazos   NotificacaoPrazo[]
  membros_banca         MembroBanca[]

  @@map("users")
}

model PeriodoLetivo {
  id            String       @id
  nome          String
  data_inicio   DateTime     @db.Date
  data_fim      DateTime     @db.Date
  ativo         Boolean      @default(false)
  criado_em     DateTime     @default(now())
  atualizado_em DateTime     @updatedAt
  prazos        PrazoEtapa[]
  tccs          TCC[]

  @@index([nome])
  @@index([data_inicio])
  @@index([data_fim])
  @@index([ativo])
  @@map("periodos_letivos")
}

model PrazoEtapa {
  id          String        @id
  periodo_id  String
  nome_etapa  String
  data_limite DateTime      @db.Date
  tipo_tcc    TipoTCC
  criado_em   DateTime      @default(now())
  periodo     PeriodoLetivo @relation(fields: [periodo_id], references: [id], onDelete: Cascade)
  notificacoes_prazos NotificacaoPrazo[]

  @@index([periodo_id])
  @@map("prazos_etapas")
}

model TCC {
  id               String       @id
  titulo           String
  tipo_tcc         TipoTCC
  aluno_id         String
  orientador_id    String
  coorientador_id  String?
  periodo_id       String
  status           StatusTCC    @default(AGUARDANDO_ACEITE)
  prazo_excedido   Boolean      @default(false)
  observacao_orientador String?
  resumo           String?
  area_tematica    String?
  curso            String       @default("Ciência da Computação")
  data_defesa      DateTime?    @db.Date
  banca            Json?
  criado_em        DateTime     @default(now())
  atualizado_em    DateTime     @updatedAt
  aluno            User         @relation("AlunoTCC", fields: [aluno_id], references: [id], onDelete: Cascade)
  orientador       User         @relation("OrientadorTCC", fields: [orientador_id], references: [id], onDelete: Restrict)
  coorientador     User?        @relation("CoorientadorTCC", fields: [coorientador_id], references: [id], onDelete: SetNull)
  periodo          PeriodoLetivo @relation(fields: [periodo_id], references: [id], onDelete: Cascade)
  edit_logs        TCCEditLog[]
  submissoes_entregaveis SubmissaoEntregavel[]
  orientacao_sessoes OrientacaoSessao[]
  apresentacoes_artigo ApresentacaoArtigo[]
  notificacoes_prazos NotificacaoPrazo[]
  banca_defesa     Banca?
  deposito_final   DepositoFinal?

  @@unique([aluno_id, periodo_id])
  @@index([orientador_id])
  @@index([coorientador_id])
  @@index([periodo_id])
  @@index([area_tematica])
  @@index([curso])
  @@index([data_defesa])
  @@map("tccs")
}

model SubmissaoEntregavel {
  id                         String   @id
  tcc_id                     String
  aluno_id                   String
  tipo_tcc                   TipoTCC
  etapa                      String
  versao                     Int
  nome_arquivo               String
  caminho_arquivo            String
  tipo_conteudo              String?
  tamanho_bytes              Int
  foi_aceito                 Boolean  @default(false)
  nome_comprovante           String?
  caminho_comprovante        String?
  tipo_conteudo_comprovante  String?
  tamanho_comprovante_bytes  Int?
  fora_do_prazo              Boolean  @default(false)
  nota_automatica            Int?
  criado_em                  DateTime @default(now())
  tcc                        TCC      @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  aluno                      User     @relation(fields: [aluno_id], references: [id], onDelete: Cascade)
  apresentacoes_artigo       ApresentacaoArtigo[]

  @@unique([tcc_id, etapa, versao], name: "uq_submissoes_entregaveis_tcc_etapa_versao")
  @@index([tcc_id])
  @@index([aluno_id])
  @@map("submissoes_entregaveis")
}

model TCCEditLog {
  id               String         @id
  tcc_id           String
  actor_user_id    String
  acao             AcaoEdicaoTCC
  observacao       String?
  dados_anteriores Json?
  dados_novos      Json
  criado_em        DateTime       @default(now())
  tcc              TCC            @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  actor            User           @relation("ActorTCCEdit", fields: [actor_user_id], references: [id], onDelete: Cascade)

  @@index([tcc_id])
  @@index([actor_user_id])
  @@map("tcc_edit_logs")
}

model PasswordResetToken {
  token     String   @id
  user_id   String
  expira_em DateTime
  usado     Boolean  @default(false)
  criado_em DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}

model OrientacaoSessao {
  id              String   @id
  tcc_id          String
  aluno_id        String
  orientador_id   String
  data_sessao     DateTime @db.Date
  resumo          String
  proximos_passos String
  criado_em       DateTime @default(now())
  tcc             TCC      @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  aluno           User     @relation("AlunoOrientacaoSessao", fields: [aluno_id], references: [id], onDelete: Cascade)
  orientador      User     @relation("OrientadorOrientacaoSessao", fields: [orientador_id], references: [id], onDelete: Cascade)

  @@index([tcc_id])
  @@index([aluno_id])
  @@index([orientador_id])
  @@map("orientacao_sessoes")
}

model ApresentacaoArtigo {
  id                String   @id
  tcc_id            String
  aluno_id          String
  submissao_id      String?
  data_apresentacao DateTime @db.Date
  tipo_veiculo      String?
  veiculo_publicacao String?
  local_apresentacao String?
  observacoes       String?
  artigo_ja_aceito  Boolean  @default(false)
  criado_em         DateTime @default(now())
  tcc               TCC      @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  aluno             User     @relation("AlunoApresentacaoArtigo", fields: [aluno_id], references: [id], onDelete: Cascade)
  submissao         SubmissaoEntregavel? @relation(fields: [submissao_id], references: [id], onDelete: SetNull)

  @@index([tcc_id])
  @@index([aluno_id])
  @@index([submissao_id])
  @@map("apresentacoes_artigo")
}

model AuditLog {
  id         String   @id
  user_id    String?
  acao       String
  entidade   String?
  descricao  String
  dados      Json?
  ip         String?
  criado_em  DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([acao])
  @@index([entidade])
  @@index([criado_em])
  @@map("audit_logs")
}

model NotificacaoPrazo {
  id          String   @id
  tcc_id      String
  aluno_id    String
  prazo_id    String
  tipo_alerta String
  canal       String   @default("EMAIL")
  enviado_em  DateTime @default(now())
  tcc         TCC      @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  aluno       User     @relation(fields: [aluno_id], references: [id], onDelete: Cascade)
  prazo       PrazoEtapa @relation(fields: [prazo_id], references: [id], onDelete: Cascade)

  @@unique([tcc_id, prazo_id, tipo_alerta], name: "uq_notificacoes_prazos_tcc_prazo_tipo", map: "uq_notificacoes_prazos_tcc_prazo_tipo")
  @@index([tcc_id])
  @@index([aluno_id])
  @@index([prazo_id])
  @@index([tipo_alerta])
  @@index([enviado_em])
  @@map("notificacoes_prazos")
}

enum PapelBanca {
  ORIENTADOR
  COORIENTADOR
  AVALIADOR_INTERNO
  AVALIADOR_EXTERNO
  SUPLENTE
}

model Banca {
  id            String        @id
  tcc_id        String        @unique
  data_defesa   DateTime
  local         String
  criado_em     DateTime      @default(now())
  atualizado_em DateTime      @updatedAt
  tcc           TCC           @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  membros       MembroBanca[]

  @@index([tcc_id])
  @@map("bancas")
}

model MembroBanca {
  id          String     @id
  banca_id    String
  user_id     String?
  nome        String
  titulacao   String
  instituicao String
  papel       PapelBanca
  banca       Banca      @relation(fields: [banca_id], references: [id], onDelete: Cascade)
  user        User?      @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([banca_id])
  @@index([user_id])
  @@map("membros_banca")
}

enum StatusDeposito {
  AGUARDANDO_ENVIO
  EM_REVISAO
  DEVOLVIDO_PARA_CORRECAO
  APROVADO
  DEPOSITADO
}

enum TipoDocumentoDeposito {
  TCC_FINAL
  ATA_DEFESA
  FOLHA_APROVACAO
  FORMULARIOS
  DECLARACOES
}

model DepositoFinal {
  id                String               @id
  tcc_id            String               @unique
  status            StatusDeposito       @default(AGUARDANDO_ENVIO)
  observacao_revisao String?
  submetido_em      DateTime?
  criado_em         DateTime             @default(now())
  atualizado_em     DateTime             @updatedAt
  tcc               TCC                  @relation(fields: [tcc_id], references: [id], onDelete: Cascade)
  documentos        DocumentoDeposito[]

  @@index([tcc_id])
  @@index([status])
  @@map("depositos_finais")
}

model DocumentoDeposito {
  id                  String                @id
  deposito_id          String
  tipo_documento       TipoDocumentoDeposito
  nome_original        String
  caminho_original     String
  mime_type            String?
  tamanho_bytes        Int
  caminho_preview_pdf  String?
  criado_em            DateTime              @default(now())
  deposito             DepositoFinal         @relation(fields: [deposito_id], references: [id], onDelete: Cascade)

  @@unique([deposito_id, tipo_documento], name: "uq_documento_deposito_tipo", map: "uq_documento_deposito_tipo")
  @@index([deposito_id])
  @@map("documentos_deposito")
}
