generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  COORDENADOR
  ALUNO
  ORIENTADOR
}

enum UserStatus {
  PENDENTE
  ATIVO
  REJEITADO
}

enum TipoTCC {
  TODOS       @map("Todos")
  MONOGRAFIA  @map("Monografia")
  ARTIGO      @map("Artigo")
}

model User {
  id                    String               @id @default(cuid())
  nome_completo         String
  email                 String               @unique
  username              String               @unique
  senha_hash            String
  perfil                Perfil
  matricula             String?
  status                UserStatus           @default(ATIVO)
  failed_login_attempts Int                  @default(0)
  blocked_until         DateTime?
  ativo                 Boolean              @default(true)
  criado_em             DateTime             @default(now())
  password_reset_tokens PasswordResetToken[]

  @@map("users")
}

model PeriodoLetivo {
  id           String       @id
  nome         String
  data_inicio  DateTime     @db.Date
  data_fim     DateTime     @db.Date
  ativo        Boolean      @default(false)
  criado_em    DateTime     @default(now())
  atualizado_em DateTime    @updatedAt
  prazos       PrazoEtapa[]

  @@index([nome])
  @@index([data_inicio])
  @@index([data_fim])
  @@index([ativo])
  @@map("periodos_letivos")
}

model PrazoEtapa {
  id          String        @id
  periodo_id  String
  nome_etapa  String
  data_limite DateTime      @db.Date
  tipo_tcc    TipoTCC
  criado_em   DateTime      @default(now())
  periodo     PeriodoLetivo @relation(fields: [periodo_id], references: [id], onDelete: Cascade)

  @@index([periodo_id])
  @@map("prazos_etapas")
}

model PasswordResetToken {
  token     String   @id
  user_id   String
  expira_em DateTime
  usado     Boolean  @default(false)
  criado_em DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_tokens")
}